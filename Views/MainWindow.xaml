<ui:FluentWindow x:Class="WebBrowser.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:WebBrowser.ViewModels"
                 xmlns:views="clr-namespace:WebBrowser.Views"
                 mc:Ignorable="d"
                 Title="WebBrowser"
                 Height="760" Width="1280"
                 MinHeight="420" MinWidth="640"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <ui:FluentWindow.InputBindings>
        <KeyBinding Modifiers="Control" Key="T" Command="{Binding NewTabCommand}" />
        <KeyBinding Modifiers="Control" Key="W"
                    Command="{Binding CloseTabCommand}"
                    CommandParameter="{Binding ActiveTab}" />
            <KeyBinding Modifiers="Control" Key="H" Command="{Binding ToggleHistoryCommand}" />
            <KeyBinding Modifiers="Control" Key="D" Command="{Binding ToggleCurrentBookmarkCommand}" />
            <KeyBinding Modifiers="Control+Shift" Key="O" Command="{Binding ToggleBookmarksCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏左侧承载标签条；系统字幕按钮渲染在右侧。 -->
        <ui:TitleBar x:Name="TitleBar" Grid.Row="0" Title="">
            <ui:TitleBar.Header>
                <views:TabStripView />
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 工具栏：导航按钮 + 地址栏 + 下载 + 进程数遥测。 -->
        <Grid Grid.Row="1" Margin="10,4,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon ArrowLeft24}"
                       Command="{Binding ActiveTab.GoBackCommand}"
                       ToolTip="Back"
                       Margin="0,0,4,0"
                       Focusable="False" />
            <ui:Button Grid.Column="1"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon ArrowRight24}"
                       Command="{Binding ActiveTab.GoForwardCommand}"
                       ToolTip="Forward"
                       Margin="0,0,4,0"
                       Focusable="False" />
            <ui:Button Grid.Column="2"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon ArrowClockwise24}"
                       Command="{Binding ActiveTab.ReloadCommand}"
                       ToolTip="Reload"
                       Margin="0,0,10,0"
                       Focusable="False" />

            <ui:TextBox x:Name="AddressBox"
                        Grid.Column="3"
                        AutomationProperties.Name="Address bar"
                        PlaceholderText="Search or enter web address"
                        Icon="{ui:SymbolIcon Search24}"
                        Text="{Binding ActiveTab.Address, Mode=OneWay, TargetNullValue=''}"
                        KeyDown="AddressBox_KeyDown" />

            <!-- 下载按钮，带活动计数角标 overlay。 -->
            <Grid Grid.Column="4" Margin="6,0,2,0" HorizontalAlignment="Right">
                <ui:Button x:Name="DownloadsButton"
                           Appearance="Transparent"
                           Icon="{ui:SymbolIcon ArrowDownload24}"
                           AutomationProperties.Name="Downloads"
                           Command="{Binding ToggleDownloadsCommand}"
                           ToolTip="Downloads"
                           Focusable="False" />
                <Border CornerRadius="8"
                        Background="#FF0078D4"
                        MinWidth="16" Height="16"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-3,-3,0"
                        Padding="4,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveDownloadCount}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ActiveDownloadCount}"
                               FontSize="10"
                               Foreground="White"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>

            <!-- 收藏本页：未收藏时显空心星标，已收藏时显实心星标。 -->
            <Grid x:Name="BookmarkButton" Grid.Column="5" Margin="4,0,2,0">
                <ui:Button Appearance="Transparent"
                           Focusable="False"
                           Icon="{ui:SymbolIcon Star24}"
                           AutomationProperties.Name="Bookmarks"
                           ToolTip="Bookmarks (Ctrl+Shift+O)"
                           Command="{Binding ToggleBookmarksCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrentPageBookmarked}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Appearance="Transparent"
                           Focusable="False"
                           Icon="{ui:SymbolIcon Star24, Filled=True}"
                           AutomationProperties.Name="Bookmarks"
                           ToolTip="Bookmarks (Ctrl+Shift+O)"
                           Command="{Binding ToggleBookmarksCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrentPageBookmarked}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </Grid>

            <!-- 历史浮层开关。 -->
            <ui:Button x:Name="HistoryButton"
                       Grid.Column="6"
                       Appearance="Transparent"
                       Focusable="False"
                       Icon="{ui:SymbolIcon History24}"
                       AutomationProperties.Name="History"
                       ToolTip="History (Ctrl+H)"
                       Command="{Binding ToggleHistoryCommand}"
                       Margin="2,0,2,0" />

            <!-- 主题切换：两个叠加按钮（dark 时显月亮，light 时显太阳），只显示其中一个。 -->
            <Grid Grid.Column="7" Margin="4,0,2,0">
                <ui:Button Appearance="Transparent"
                           Focusable="False"
                           Icon="{ui:SymbolIcon WeatherMoon24}"
                           AutomationProperties.Name="Switch to light theme"
                           ToolTip="Switch to light theme"
                           Command="{Binding ToggleThemeCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Appearance="Transparent"
                           Focusable="False"
                           Icon="{ui:SymbolIcon WeatherSunny24}"
                           AutomationProperties.Name="Switch to dark theme"
                           ToolTip="Switch to dark theme"
                           Command="{Binding ToggleThemeCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </Grid>

            <!-- 调试遥测：WebView2 进程数 + 总 working set（后台标签挂起时下降）。 -->
            <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,2,0">
                <TextBlock Text="{Binding WebViewProcessCount, StringFormat='wv2: {0}'}"
                           Opacity="0.5" FontSize="11" />
                <TextBlock Text="{Binding WebViewMemoryMb, StringFormat='· {0} MB'}"
                           Opacity="0.5" FontSize="11"
                           Margin="6,0,0,0" />
            </StackPanel>
        </Grid>

        <!--
            标签内容区。所有标签的 WebView2 控件 overlay 在同一个 Grid 里，全生命周期保持 parented，
            仅活动标签可见。我们刻意不用 stock TabControl —— 它的内容回收会 unparent/reparent WebView2，
            摧毁其宿主 HWND。
        -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Tabs}" Focusable="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TabViewModel}">
                    <ContentPresenter Content="{Binding WebView.Control}"
                                      Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 下载浮层，由工具栏按钮切换。 -->
        <Popup IsOpen="{Binding IsDownloadsOpen}"
               PlacementTarget="{Binding ElementName=DownloadsButton}"
               Placement="Bottom"
               HorizontalOffset="-338"
               VerticalOffset="2"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <views:DownloadPanelView />
        </Popup>

        <!-- 历史浮层。 -->
        <Popup IsOpen="{Binding IsHistoryOpen}"
               PlacementTarget="{Binding ElementName=HistoryButton}"
               Placement="Bottom"
               HorizontalOffset="-338"
               VerticalOffset="2"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <views:HistoryPanelView />
        </Popup>

        <!-- 书签浮层。 -->
        <Popup IsOpen="{Binding IsBookmarksOpen}"
               PlacementTarget="{Binding ElementName=BookmarkButton}"
               Placement="Bottom"
               HorizontalOffset="-338"
               VerticalOffset="2"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <views:BookmarksPanelView />
        </Popup>
    </Grid>
</ui:FluentWindow>
