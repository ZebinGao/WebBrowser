<ui:FluentWindow x:Class="WebBrowser.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:WebBrowser.ViewModels"
                 mc:Ignorable="d"
                 Title="WebBrowser"
                 Height="760" Width="1280"
                 MinHeight="420" MinWidth="640"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar: drag region + system caption (min/max/close) buttons -->
        <ui:TitleBar x:Name="TitleBar" Grid.Row="0" Title="WebBrowser" />

        <!-- Toolbar: navigation buttons + address bar -->
        <Grid Grid.Row="1" Margin="10,6,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon ArrowLeft24}"
                       Command="{Binding ActiveTab.GoBackCommand}"
                       ToolTip="Back"
                       Margin="0,0,4,0" />
            <ui:Button Grid.Column="1"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon ArrowRight24}"
                       Command="{Binding ActiveTab.GoForwardCommand}"
                       ToolTip="Forward"
                       Margin="0,0,4,0" />
            <ui:Button Grid.Column="2"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon ArrowClockwise24}"
                       Command="{Binding ActiveTab.ReloadCommand}"
                       ToolTip="Reload"
                       Margin="0,0,10,0" />

            <ui:TextBox x:Name="AddressBox"
                        Grid.Column="3"
                        PlaceholderText="Search or enter web address"
                        Icon="{ui:SymbolIcon Search24}"
                        Text="{Binding ActiveTab.Address, Mode=OneWay, TargetNullValue=''}"
                        KeyDown="AddressBox_KeyDown" />
        </Grid>

        <!--
            Tab content region. Every tab's WebView2 control is overlaid in a single Grid and kept
            parented for its whole lifetime; only the active tab is visible. We deliberately do NOT
            use a stock TabControl here — its content recycling would unparent/reparent the WebView2,
            destroying its host HWND. (M2 adds the visible tab strip above this region.)
        -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Tabs}" Focusable="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TabViewModel}">
                    <ContentPresenter Content="{Binding WebView.Control}"
                                      Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</ui:FluentWindow>
