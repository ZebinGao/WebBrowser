<UserControl x:Class="WebBrowser.Views.BookmarksPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:WebBrowser.Models"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="380">
    <Border Background="{ui:ThemeResource ApplicationBackgroundBrush}"
            BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0"
            TextElement.Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header: title on the left, "bookmark this page" toggle on the right. -->
            <Grid Grid.Row="0" Margin="14,10,14,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Bookmarks"
                           FontWeight="SemiBold"
                           FontSize="13"
                           VerticalAlignment="Center" />
                <ui:Button Grid.Column="1"
                           Appearance="Transparent"
                           FontSize="11"
                           Padding="8,2"
                           Focusable="False"
                           ToolTip="Bookmark or un-bookmark this page (Ctrl+D)"
                           Command="{Binding ToggleCurrentBookmarkCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Content" Value="Add this page" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrentPageBookmarked}" Value="True">
                                    <Setter Property="Content" Value="Remove" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="440">
                <ItemsControl ItemsSource="{Binding Bookmarks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Bookmark}">
                            <!-- The whole row opens the bookmark; the nested Dismiss button removes it. -->
                            <Border BorderThickness="0,1,0,0" BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}">
                                <ui:Button Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch"
                                           Padding="0"
                                           AutomationProperties.Name="{Binding Title}"
                                           ToolTip="{Binding Url}"
                                           Command="{Binding DataContext.OpenBookmarkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}">
                                    <Grid Margin="14,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="250" />
                                            <TextBlock Text="{Binding Url}"
                                                       Opacity="0.5"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="250" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1"
                                                   Appearance="Transparent"
                                                   Icon="{ui:SymbolIcon Dismiss24}"
                                                   AutomationProperties.Name="Remove bookmark"
                                                   Command="{Binding DataContext.RemoveBookmarkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"
                                                   Width="30" Height="30" Padding="0"
                                                   VerticalAlignment="Center"
                                                   Focusable="False"
                                                   ToolTip="Remove bookmark" />
                                    </Grid>
                                </ui:Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Grid.Row="1"
                       Text="No bookmarks yet — click the star to save a page."
                       Opacity="0.5"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Margin="20">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Bookmarks.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
