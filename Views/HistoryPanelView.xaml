<UserControl x:Class="WebBrowser.Views.HistoryPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:WebBrowser.Models"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="380">
    <Border Background="{ui:ThemeResource ApplicationBackgroundBrush}"
            BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0"
            TextElement.Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 头部：左侧标题，右侧 Clear all -->
            <Grid Grid.Row="0" Margin="14,10,14,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="History"
                           FontWeight="SemiBold"
                           FontSize="13"
                           VerticalAlignment="Center" />
                <ui:Button Grid.Column="1"
                           Appearance="Transparent"
                           Content="Clear all"
                           AutomationProperties.Name="Clear all history"
                           Command="{Binding ClearHistoryCommand}"
                           FontSize="11"
                           Padding="8,2"
                           Focusable="False"
                           ToolTip="Clear all history" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="440">
                <ItemsControl ItemsSource="{Binding History}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:HistoryEntry}">
                            <Border BorderThickness="0,1,0,0" BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}">
                                <ui:Button Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch"
                                           Padding="0"
                                           AutomationProperties.Name="{Binding Title}"
                                           ToolTip="{Binding Url}"
                                           Command="{Binding DataContext.OpenHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}">
                                    <Grid Margin="14,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="210" />
                                                <TextBlock Text="{Binding VisitCount, StringFormat=' · {0}x'}"
                                                           Opacity="0.45"
                                                           FontSize="11"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           ToolTip="Visit count" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Url}"
                                                       Opacity="0.5"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="250" />
                                            <TextBlock Text="{Binding LastVisited, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       Opacity="0.4"
                                                       FontSize="10"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1"
                                                   Appearance="Transparent"
                                                   Icon="{ui:SymbolIcon Dismiss24}"
                                                   AutomationProperties.Name="Remove from history"
                                                   Command="{Binding DataContext.RemoveHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"
                                                   Width="30" Height="30" Padding="0"
                                                   VerticalAlignment="Center"
                                                   Focusable="False"
                                                   ToolTip="Remove from history" />
                                    </Grid>
                                </ui:Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 空状态 -->
            <TextBlock Grid.Row="1"
                       Text="No history yet — pages you visit will show up here."
                       Opacity="0.5"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Margin="20">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding History.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
